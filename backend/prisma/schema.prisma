generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  admin
  staff
}

enum OrderStatus {
  pending
  confirmed
  shipping
  delivered
  cancelled
}

enum PaymentMethod {
  cash
  transfer
}

model User {
  id        String   @id
  email     String   @unique
  password  String
  fullName  String
  name      String?
  phone     String
  address   String
  role      Role     @default(customer)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
  reviews   Review[]
}

model Category {
  id          String @id
  name        String
  slug        String @unique
  description String
  bookCount   Int    @default(0)
  books       Book[]
}

model Book {
  id            String   @id
  title         String
  author        String
  price         Int
  originalPrice Int?
  description   String   @db.Text
  coverImage    String
  category      String
  categoryId    String?
  categoryRel   Category? @relation(fields: [categoryId], references: [id])
  publisher     String
  publishYear   Int
  pages         Int
  language      String
  isbn          String
  stock         Int      @default(0)
  soldCount     Int?
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  isFeatured    Boolean  @default(false)
  isNewArrival  Boolean  @default(false)
  isBestSeller  Boolean  @default(false)
  orderItems    OrderItem[]
  reviews       Review[]
}

model Order {
  id              String        @id
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  items           OrderItem[]
  totalAmount     Int
  shippingAddress String
  phone           String
  paymentMethod   PaymentMethod
  status          OrderStatus   @default(pending)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bookId   String
  book     Book   @relation(fields: [bookId], references: [id])
  quantity Int
  price    Int
}

model Review {
  id        String   @id
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  userName  String
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now())
}

model InventoryLog {
  id        String   @id
  bookId    String
  type      String
  quantity  Int
  note      String
  createdAt DateTime @default(now())
  createdBy String
}
